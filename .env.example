# Rename this file to ".env" and fill in the values before running the example.

MSSQL_SERVER=your-sql-server-hostname
MSSQL_DATABASE='your_database_name'
MSSQL_USERNAME=your_username
MSSQL_PASSWORD=your_password

# Optional overrides
MSSQL_DRIVER='ODBC Driver 18 for SQL Server'
SQL_ENCRYPT=yes
TRUST_SERVER_CERTIFICATE=true

# Optional for SOPRA CRUD workflows.
# The read-only examples do not use this value, but the full SOPRA app writes it
# into audit columns during insert and update operations.
APP_USER=your_hdm_account
